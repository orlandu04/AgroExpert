<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="#F8F9FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Título -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="✏️ Editar Planta"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#2E7D32"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <!-- Imagen de la planta -->
        <ImageView
            android:id="@+id/imgPlantaEditar"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_gravity="center"
            android:background="#E0E0E0"
            android:scaleType="centerCrop"
            android:layout_marginBottom="20dp" />

        <!-- Botones de imagen -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <Button
                android:id="@+id/btnTomarFotoEditar"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:layout_weight="1"
                android:text="📷 Cambiar Foto"
                android:textSize="14sp"
                android:layout_marginEnd="8dp"
                android:backgroundTint="#4CAF50"
                android:textColor="#FFFFFF" />

            <Button
                android:id="@+id/btnGaleriaEditar"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:layout_weight="1"
                android:text="🖼️ Galería"
                android:textSize="14sp"
                android:layout_marginStart="8dp"
                android:backgroundTint="#2196F3"
                android:textColor="#FFFFFF" />

        </LinearLayout>

        <!-- Título del registro -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:boxBackgroundMode="outline"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusTopStart="12dp"
            app:boxStrokeColor="#4CAF50"
            app:hintTextColor="#4CAF50">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etTituloRegistroEditar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Título del registro *"
                android:textSize="16sp"
                android:padding="16dp" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Nombre de la planta -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:boxBackgroundMode="outline"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusTopStart="12dp"
            app:boxStrokeColor="#4CAF50"
            app:hintTextColor="#4CAF50">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etNombrePlantaEditar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nombre de la planta *"
                android:textSize="16sp"
                android:padding="16dp" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Descripción breve -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:boxBackgroundMode="outline"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusTopStart="12dp"
            app:boxStrokeColor="#4CAF50"
            app:hintTextColor="#4CAF50">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etDescripcionBreveEditar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Descripción breve *"
                android:textSize="16sp"
                android:padding="16dp"
                android:minLines="3"
                android:maxLines="5" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Categoría / Tipo -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:boxBackgroundMode="outline"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusTopStart="12dp"
            app:boxStrokeColor="#4CAF50"
            app:hintTextColor="#4CAF50">

            <AutoCompleteTextView
                android:id="@+id/actvCategoriaEditar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Categoría / Tipo"
                android:textSize="16sp"
                android:padding="16dp"
                android:completionThreshold="1" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Prioridad -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:boxBackgroundMode="outline"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusTopStart="12dp"
            app:boxStrokeColor="#4CAF50"
            app:hintTextColor="#4CAF50">

            <AutoCompleteTextView
                android:id="@+id/actvPrioridadEditar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Prioridad *"
                android:textSize="16sp"
                android:padding="16dp"
                android:completionThreshold="1" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Fecha de creación -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="📅 Fecha de creación:"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvFechaCreacionEditar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hoy"
                android:textSize="14sp"
                android:textColor="#2196F3"
                android:padding="12dp"
                android:background="#E3F2FD"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

        <!-- SECCIÓN DE CUIDADOS -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="💧 Configuración de Cuidados"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#2E7D32"
            android:layout_marginBottom="16dp" />

        <!-- Días de riego -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="💧 Días entre riegos:"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <SeekBar
            android:id="@+id/seekBarRiegoEditar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="29"
            android:progress="6"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvDiasRiegoEditar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="7 días"
            android:textSize="14sp"
            android:textColor="#2196F3"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <!-- Días de fertilizante -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🌱 Días entre fertilizaciones:"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <SeekBar
            android:id="@+id/seekBarFertilizanteEditar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="89"
            android:progress="29"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvDiasFertilizanteEditar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="30 días"
            android:textSize="14sp"
            android:textColor="#FF9800"
            android:gravity="center"
            android:layout_marginBottom="20dp" />

        <!-- Notificaciones -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🔔 Recibir notificaciones de cuidados"
                android:textSize="16sp"
                android:textStyle="bold" />

            <Switch
                android:id="@+id/switchNotificacionesEditar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true" />

        </LinearLayout>

        <!-- Botón Guardar Cambios -->
        <Button
            android:id="@+id/btnGuardarCambios"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="💾 Guardar Cambios"
            android:textSize="18sp"
            android:textStyle="bold"
            android:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF" />

    </LinearLayout>

</ScrollView>