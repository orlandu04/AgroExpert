<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp"
    android:background="@drawable/bg_header_card">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header Elegante -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="24dp"
            android:background="@drawable/bg_header_card"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌿"
                android:textSize="48sp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Diagnóstico con IA"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#1B5E20"
                android:gravity="center" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Identifica plantas y obtén recomendaciones inteligentes"
                android:textSize="14sp"
                android:textColor="#4CAF50"
                android:gravity="center"
                android:lineSpacingExtra="2dp"
                android:layout_marginTop="4dp" />

        </LinearLayout>

        <!-- Tarjeta de Imagen -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="@android:color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📷"
                    android:textSize="40sp"
                    android:layout_marginBottom="12dp" />

                <ImageView
                    android:id="@+id/imgPlanta"
                    android:layout_width="220dp"
                    android:layout_height="220dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_image_placeholder_modern"
                    android:scaleType="centerCrop"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tvSeleccionaImagen"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Selecciona una imagen para analizar"
                    android:textSize="16sp"
                    android:textColor="#757575"
                    android:gravity="center"
                    android:layout_marginTop="12dp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Tarjeta de Acciones -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@android:color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Botones de selección mejorados -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTomarFoto"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:text="📷 Cámara"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginEnd="8dp"
                        android:icon="@android:drawable/ic_menu_camera"
                        app:iconGravity="textStart"
                        app:cornerRadius="12dp"
                        app:backgroundTint="#4CAF50"
                        android:textColor="#FFFFFF" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnGaleria"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:text="🖼️ Galería"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginStart="8dp"
                        android:icon="@android:drawable/ic_menu_gallery"
                        app:iconGravity="textStart"
                        app:cornerRadius="12dp"
                        app:backgroundTint="#2196F3"
                        android:textColor="#FFFFFF" />

                </LinearLayout>

                <!-- Botón analizar mejorado -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAnalizar"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:text="🤖 Analizar con IA"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:icon="@android:drawable/ic_menu_manage"
                    app:iconGravity="textStart"
                    app:cornerRadius="14dp"
                    app:backgroundTint="#FF6F00"
                    android:textColor="#FFFFFF"
                    app:strokeColor="#FF9800"
                    app:strokeWidth="2dp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Progress Bar Mejorado -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardProgress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#E8F5E9"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="20dp"
                android:gravity="center_vertical">

                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginEnd="16dp"
                    android:indeterminateTint="#4CAF50" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Analizando imagen con IA..."
                    android:textSize="15sp"
                    android:textColor="#2E7D32"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌱"
                    android:textSize="20sp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Resultados - Tarjeta Elegante -->
        <androidx.cardview.widget.CardView
            android:id="@+id/resultadoLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="@android:color/white"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Header Resultados -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✅"
                        android:textSize="24sp"
                        android:layout_marginEnd="12dp" />

                    <TextView
                        android:id="@+id/tvResultado"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Resultado del Análisis"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#1B5E20" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🎯"
                        android:textSize="20sp" />

                </LinearLayout>

                <!-- Nombre Científico -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="#F1F8E9"
                    android:padding="16dp"
                    android:layout_marginBottom="16dp"
                    android:backgroundTint="#F1F8E9">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📚"
                        android:textSize="16sp"
                        android:layout_marginEnd="12dp" />

                    <TextView
                        android:id="@+id/tvNombreCientifico"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Nombre científico"
                        android:textSize="14sp"
                        android:textStyle="italic"
                        android:textColor="#4CAF50" />

                </LinearLayout>

                <!-- Sección Estado -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="#E8F5E9"
                    app:strokeColor="#4CAF50"
                    app:strokeWidth="1dp"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="📊 Estado de la Planta"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#2E7D32"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:id="@+id/tvEstado"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Cargando análisis..."
                            android:textSize="14sp"
                            android:textColor="#424242"
                            android:lineSpacingExtra="4dp" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Sección Plagas -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="#FFF3E0"
                    app:strokeColor="#FF9800"
                    app:strokeWidth="1dp"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="🦠 Análisis de Plagas"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#E65100"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:id="@+id/tvPlagas"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Analizando posibles plagas..."
                            android:textSize="14sp"
                            android:textColor="#424242"
                            android:lineSpacingExtra="4dp" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Sección Recomendaciones -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="#E3F2FD"
                    app:strokeColor="#2196F3"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="💡 Recomendaciones"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#1565C0"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:id="@+id/tvRecomendaciones"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Generando recomendaciones personalizadas..."
                            android:textSize="14sp"
                            android:textColor="#424242"
                            android:lineSpacingExtra="4dp" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Botón de acción adicional -->
                <com.google.android.material.button.MaterialButton
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="💾 Guardar Diagnóstico"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:cornerRadius="12dp"
                    app:backgroundTint="#4CAF50"
                    android:textColor="#FFFFFF"
                    android:layout_marginTop="20dp"
                    android:visibility="gone" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>