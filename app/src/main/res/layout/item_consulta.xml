<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <!-- ImageView para la imagen -->
        <ImageView
            android:id="@+id/imgConsulta"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:scaleType="centerCrop"
            android:background="#E8F5E9"
            android:contentDescription="Imagen de la planta"
            android:layout_marginEnd="16dp" />

        <!-- Contenido textual -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Header con nombre y probabilidad -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvNombrePlanta"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Nombre Planta"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#1B5E20"
                    android:ellipsize="end"
                    android:maxLines="1" />

                <TextView
                    android:id="@+id/tvProbabilidad"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="95.5%"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="#2E7D32"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:gravity="center"
                    android:layout_marginStart="8dp" />

            </LinearLayout>

            <!-- Fecha -->
            <TextView
                android:id="@+id/tvFecha"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="01/01/2024 10:30 AM"
                android:textSize="15sp"
                android:textColor="#424242"
                android:layout_marginTop="4dp" />

            <!-- Resumen -->
            <TextView
                android:id="@+id/tvResumen"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Resumen del diagnóstico aparecerá aquí..."
                android:textSize="16sp"
                android:textColor="#000000"
                android:layout_marginTop="8dp"
                android:lineSpacingExtra="4dp"
                android:maxLines="2"
                android:ellipsize="end" />

            <!-- Botones de acción -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp"
                android:weightSum="3">

                <Button
                    android:id="@+id/btnVerDetalles"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:text="👁️ Ver"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/btn_outline_primary"
                    android:textColor="#1B5E20"
                    android:padding="0dp" />

                <Button
                    android:id="@+id/btnGenerarPDF"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:text="📄 PDF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/btn_outline_accent"
                    android:textColor="#E65100"
                    android:padding="0dp" />

                <Button
                    android:id="@+id/btnEliminar"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:text="🗑️"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginStart="4dp"
                    android:background="@drawable/btn_outline_error"
                    android:textColor="#C62828"
                    android:padding="0dp" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>